# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_REASONER_MODEL=deepseek-v4-pro

# BGE-M3 Embedding (SiliconFlow API by default, set BGE_M3_USE_LOCAL=true for local GPU)
BGE_M3_USE_LOCAL=false
BGE_M3_MODEL_PATH=BAAI/bge-m3
BGE_M3_DEVICE=cuda:0
BGE_M3_BATCH_SIZE=32
BGE_M3_MAX_LENGTH=8192

# SiliconFlow Embedding API
SILICONFLOW_API_KEY=sk-your-siliconflow-key
SILICONFLOW_EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3

# Milvus (Standalone)
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=agentic_rag

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# PaddleOCR
PADDLEOCR_VL_MODEL_DIR=./PaddleOCR-VL-1.5
LAYOUT_DETECTION_MODEL_DIR=./PP-DocLayoutV3
CUDA_VISIBLE_DEVICES=0

# MinerU
MINERU_MODEL_SOURCE=modelscope
MINERU_OUTPUT_DIR=./data/processed

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
HYBRID_TOP_K=20
HYBRID_DENSE_WEIGHT=0.5
HYBRID_SPARSE_WEIGHT=0.3
HYBRID_BM25_WEIGHT=0.2
HYBRID_RRF_K=60

# Agent
AGENT_MAX_ITERATIONS=5
AGENT_TEMPERATURE=0.1

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4
